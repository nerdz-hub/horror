-- ลูปสำหรับ Auto Merchant (TP + Hold E)
task.spawn(function()
    while task.wait(0.1) do
        if AutoMerchantEnabled then
            local char = LocalPlayer.Character
            if char and char:FindFirstChild("HumanoidRootPart") then
                
                -- ตรวจสอบตำแหน่ง Map.Shack ตามโครงสร้างแมพ
                local shack = workspace:FindFirstChild("Map") and workspace.Map:FindFirstChild("Shack")
                
                if shack then
                    -- 1. Auto TP ไปหา Merchant (เยื้องมาข้างหน้า 3 หน่วยกันติดบัค)
                    local merchant = shack:FindFirstChild("Merchant")
                    if merchant then
                        char.HumanoidRootPart.CFrame = merchant.CFrame * CFrame.new(0, 0, 3)
                    end
                    
                    -- 2. Auto Open Shop (ยิงฟังก์ชันกดค้าง ProximityPrompt ทันที)
                    local shopPart = shack:FindFirstChild("ShopPart")
                    if shopPart then
                        local prompt = shopPart:FindFirstChildWhichIsA("ProximityPrompt")
                        if prompt then
                            fireproximityprompt(prompt, 1)
                        end
                    end
                end
                
            end
        end
    end
end)

