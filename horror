-- ==================== [ SYSTEM VARIABLES ] ====================
local AutoMerchantEnabled = false
local IY_FB_Connection = nil

-- ส่วนเก็บค่าเดิมตาม Source Code ของ IY
local IY_Backup = {
    Ambient = Lighting.Ambient,
    OutdoorAmbient = Lighting.OutdoorAmbient,
    Brightness = Lighting.Brightness,
    ClockTime = Lighting.ClockTime,
    FogEnd = Lighting.FogEnd,
    FogColor = Lighting.FogColor,
    GlobalShadows = Lighting.GlobalShadows
}

-- ==================== [ FUNCTIONS ] ====================

-- ถอดซอร์สโค้ดฟังก์ชัน loopfullbright จาก Infinite Yield ตัวเต็ม
local function IY_LoopFullbright()
    if IY_FB_Connection then IY_FB_Connection:Disconnect() end
    
    IY_FB_Connection = RunService.RenderStepped:Connect(function()
        Lighting.Ambient = Color3.fromRGB(255, 255, 255)
        Lighting.OutdoorAmbient = Color3.fromRGB(255, 255, 255)
        Lighting.Brightness = 2
        Lighting.ClockTime = 14
        Lighting.FogEnd = 999999
        Lighting.GlobalShadows = false
        
        -- ล้างเอฟเฟกต์มืดมน (Atmosphere/ColorCorrection) ที่มาทับแสงแบบใน IY Source
        for _, v in ipairs(Lighting:GetChildren()) do
            if v:IsA("Atmosphere") or v:IsA("ColorCorrectionEffect") or v:IsA("BlurEffect") then
                pcall(function() v.Parent = nil end)
            end
        end
        for _, v in ipairs(workspace.CurrentCamera:GetChildren()) do
            if v:IsA("ColorCorrectionEffect") or v:IsA("BlurEffect") then
                pcall(function() v.Parent = nil end)
            end
        end
    end)
end

-- ถอดซอร์สโค้ดฟังก์ชัน unloopfullbright จาก Infinite Yield
local function IY_UnloopFullbright()
    if IY_FB_Connection then
        IY_FB_Connection:Disconnect()
        IY_FB_Connection = nil
    end
    -- คืนค่าทุกอย่างกลับสู่ค่าดั้งเดิมที่ Backup ไว้
    Lighting.Ambient = IY_Backup.Ambient
    Lighting.OutdoorAmbient = IY_Backup.OutdoorAmbient
    Lighting.Brightness = IY_Backup.Brightness
    Lighting.ClockTime = IY_Backup.ClockTime
    Lighting.FogEnd = IY_Backup.FogEnd
    Lighting.FogColor = IY_Backup.FogColor
    Lighting.GlobalShadows = IY_Backup.GlobalShadows
end

